# Copy this file to .env and fill in your Cloudflare credentials
# cp skills/obsidian-cloudflare-pages/.env.example skills/obsidian-cloudflare-pages/.env

CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Optional: basic auth credentials (used when basicAuth.enabled=true)
BASIC_AUTH_USERNAME=YOURUSERID
BASIC_AUTH_PASSWORD=YOURPASSWORD
